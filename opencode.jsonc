{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "instructions": ["AGENTS.md"],
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "initialization": {
        "preferences": {
          "includePackageJsonAutoImports": "on",
          "autoImportFileExcludePatterns": ["node_modules"]
        }
      }
    }
  },
  "mcp": {
    "jira": {
      "type": "local",
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-jira"],
      "enabled": true,
      "env": {
        "ATLASSIAN_SITE_NAME": "varunhari777",
        "ATLASSIAN_USER_EMAIL": "varunhari777@gmail.com",
        "ATLASSIAN_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}"
      }
    }
  },
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "test-plan-creator": {
      "description": "Analyzes websites and creates comprehensive test plans, strategy docs, and test cases",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "test-script-creator": {
      "description": "Generates Selenium TestNG test scripts from test cases using the project's page object model",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "test-script-reviewer": {
      "description": "Reviews test scripts for code quality, best practices, and adherence to project conventions",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "test-script-healer": {
      "description": "Diagnoses and fixes broken test scripts (locator changes, timeout issues, API changes)",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    },
    "test-script-executor": {
      "description": "Runs Selenium TestNG tests and reports pass/fail results with logs",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "shell": "allow"
      }
    },
    "orchestrator": {
      "description": "Runs the full test pipeline: plan -> create -> review -> heal -> execute",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
